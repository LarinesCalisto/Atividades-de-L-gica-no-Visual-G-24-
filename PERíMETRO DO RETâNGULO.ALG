Algoritmo "Perímetro do Retângulo"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson
// Descriçăo: Leia a base e a altura de um retângulo e calcule
// seu perímetro.
// Autor(a): Larissa
// Data atual: 18/04/2026
Var
// Seçăo de Declaraçőes das variáveis
lado1, lado2, lado3, lado4, perimetro: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreval ("Digite o primeiro lado do retangulo")
leia(lado1)
escreval ("Digite o segundo lado do retangulo")
leia(lado2)
escreval ("Digite o terceiro lado do retangulo")
leia(lado3)
escreval ("Digite o quarto lado do retangulo")
leia(lado4)
perimetro <- lado1+lado2+lado3+lado4
escreval ("O perimetro do retângulo é: ", perimetro)


Fimalgoritmo