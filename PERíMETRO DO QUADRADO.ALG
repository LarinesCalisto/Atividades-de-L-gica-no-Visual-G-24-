Algoritmo "Perímetro do Quadrado"
// Disciplina: [Lógica de Programaçăo com visualG]
// Professor: Jailson
// Descriçăo: Leia o valor do lado de um quadrado e calcule o perímetro.
// Autor(a): Larissa
// Data atual: 18/04/2026
// Seçăo de Declaraçőes das variáveis
var
lado1, lado2,lado3, lado4,  perimetro: inteiro


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
escreval ("Digite o primeiro lado do quadrado")
leia (lado1)
escreval ("Digite o segundo lado do quadrado")
leia (lado2)
escreval ("Digite o terceiro lado do quadrado")
leia (lado3)
escreval ("Digite o quarto lado do quadrado")
leia (lado4)
perimetro <- lado1+lado2+lado3+lado4
escreval ("O perimetro do quadrado é: ", perimetro)



Fimalgoritmo